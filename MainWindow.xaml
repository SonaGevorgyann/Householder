<Window x:Class="HouseholderSolver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Householder Solver"
        Height="640"
        Width="960"
        Background="#12111A"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- ═══ COLOR PALETTE ═══ -->
        <SolidColorBrush x:Key="BgPanel"     Color="#1C1B2A"/>
        <SolidColorBrush x:Key="BgRow"       Color="#1C1B2A"/>
        <SolidColorBrush x:Key="BgRowAlt"    Color="#211F32"/>
        <SolidColorBrush x:Key="BgInput"     Color="#12111A"/>
        <SolidColorBrush x:Key="BgBottom"    Color="#1C1B2A"/>
        <SolidColorBrush x:Key="BgStatPill"  Color="#12111A"/>
        <SolidColorBrush x:Key="BorderColor" Color="#3D3B5C"/>
        <SolidColorBrush x:Key="BorderInput" Color="#4A4770"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#5B4FCF"/>
        <SolidColorBrush x:Key="AccentBlue"  Color="#2B6CB0"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#D0CAEA"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#7A72B8"/>
        <SolidColorBrush x:Key="TextResult"  Color="#7EE8A2"/>

        <!-- ═══ PANEL TITLE ═══ -->
        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ═══ STAT LABEL ═══ -->
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ═══ STAT VALUE ═══ -->
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="{StaticResource TextResult}"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="FontFamily"        Value="Consolas"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ═══ PRIMARY BUTTON (Purple) ═══
             Key fix: use TextBlock inside Border instead of ContentPresenter
             so the text is never clipped by layout rounding issues. -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"          Value="{StaticResource AccentPurple}"/>
            <Setter Property="Foreground"          Value="#E8E4FF"/>
            <Setter Property="BorderThickness"     Value="0"/>
            <Setter Property="FontSize"            Value="13"/>
            <Setter Property="FontWeight"          Value="SemiBold"/>
            <Setter Property="Height"              Value="36"/>
            <Setter Property="MinWidth"            Value="130"/>
            <Setter Property="Cursor"              Value="Hand"/>
            <Setter Property="Margin"              Value="8,0,0,0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding"   Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True"
                                Padding="16,0">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#6F63D6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A3FB8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ ACCENT BUTTON (Blue) ═══ -->
        <Style x:Key="BtnAccent" TargetType="Button">
            <Setter Property="Background"          Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground"          Value="#BEE3F8"/>
            <Setter Property="BorderThickness"     Value="0"/>
            <Setter Property="FontSize"            Value="13"/>
            <Setter Property="FontWeight"          Value="SemiBold"/>
            <Setter Property="Height"              Value="36"/>
            <Setter Property="MinWidth"            Value="130"/>
            <Setter Property="Cursor"              Value="Hand"/>
            <Setter Property="Margin"              Value="8,0,0,0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding"   Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True"
                                Padding="16,0">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3478B8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A5080"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TEXTBOX ═══ -->
        <Style TargetType="TextBox">
            <Setter Property="Background"          Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"          Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"         Value="{StaticResource BorderInput}"/>
            <Setter Property="BorderThickness"     Value="1"/>
            <Setter Property="FontSize"            Value="13"/>
            <Setter Property="CaretBrush"          Value="{StaticResource TextPrimary}"/>
            <Setter Property="SelectionBrush"      Value="{StaticResource AccentPurple}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="8,0"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentPurple}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ DATAGRID ═══ -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="{StaticResource BgPanel}"/>
            <Setter Property="Foreground"               Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="RowBackground"            Value="{StaticResource BgRow}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BgRowAlt}"/>
            <Setter Property="GridLinesVisibility"      Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="VerticalGridLinesBrush"   Value="{StaticResource BorderColor}"/>
            <Setter Property="HeadersVisibility"        Value="None"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="RowHeight"                Value="30"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="SelectionUnit"            Value="Cell"/>
        </Style>

        <!-- ═══ DATAGRID CELL ═══ -->
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background"  Value="#2E2B45"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentPurple}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════
             TOP: THREE DATA PANELS
        ═══════════════════════════════════════ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- ── MATRIX A ── -->
            <Border Grid.Column="0"
                    Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Margin="0,0,6,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,0,0,1"
                            Padding="14,0">
                        <TextBlock Text="Matrix A" Style="{StaticResource PanelTitle}"/>
                    </Border>

                    <!--
                        AutoGeneratingColumn handler in code-behind must call:
                            e.Cancel = true;
                        for any column whose type is not a primitive/string,
                        which eliminates the (Collection) column entirely.
                        Bind ItemsSource to a DataTable for cleanest results.
                    -->
                    <DataGrid x:Name="MatrixGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="True"
                              
                              CanUserAddRows="False"
                              CanUserReorderColumns="False"
                              CanUserSortColumns="False"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>

            <!-- ── VECTOR b ── -->
            <Border Grid.Column="1"
                    Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Margin="0,0,6,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,0,0,1"
                            Padding="14,0">
                        <TextBlock Text="Vector b" Style="{StaticResource PanelTitle}"/>
                    </Border>

                    <DataGrid x:Name="VectorGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="True"
                              
                              CanUserAddRows="False"
                              CanUserReorderColumns="False"
                              CanUserSortColumns="False"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>

            <!-- ── RESULT x ── -->
            <Border Grid.Column="2"
                    Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,0,0,1"
                            Padding="14,0">
                        <TextBlock Text="Result x" Style="{StaticResource PanelTitle}"/>
                    </Border>

                    <DataGrid x:Name="ResultGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="True"
                             
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserReorderColumns="False"
                              CanUserSortColumns="False"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Foreground"      Value="{StaticResource TextResult}"/>
                                <Setter Property="FontFamily"      Value="Consolas"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding"         Value="6,4"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background"  Value="#1A2E22"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource TextResult}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                    </DataGrid>
                </Grid>
            </Border>

        </Grid>

        <!-- ═══════════════════════════════════════
             BOTTOM: CONTROL BAR
        ═══════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource BgBottom}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                CornerRadius="10"
                Height="58"
                Margin="0,10,0,0">

            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: size + buttons -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <TextBlock Text="Size"
                               Style="{StaticResource StatLabel}"
                               Margin="0,0,8,0"/>

                    <TextBox x:Name="SizeBox"
                             Width="58"
                             Height="36"
                             TextAlignment="Center"/>

                    <Button Content="Create Matrix"
                            Style="{StaticResource BtnPrimary}"
                            Click="Create_Click"/>

                    <Button Content="Solve  Ax = b"
                            Style="{StaticResource BtnAccent}"
                            Click="Solve_Click"/>

                </StackPanel>

                <!-- RIGHT: stat pills -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Border Background="{StaticResource BgStatPill}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,6"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Residual ‖r‖"
                                       Style="{StaticResource StatLabel}"
                                       Margin="0,0,8,0"/>
                            <TextBlock x:Name="ResidualText"
                                       Style="{StaticResource StatValue}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource BgStatPill}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="det(A)"
                                       Style="{StaticResource StatLabel}"
                                       Margin="0,0,8,0"/>
                            <TextBlock x:Name="DeterminantText"
                                       Style="{StaticResource StatValue}"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>